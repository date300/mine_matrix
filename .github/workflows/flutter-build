name: Flutter Web Deploy via FTP

on:
  push:
    branches:
      - main

# Node.js ২৪ এবং ফিউচার আপডেট সাপোর্ট নিশ্চিত করার জন্য
env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest

    steps:
      - name: 🚚 Checkout Code
        uses: actions/checkout@v4 # Node deprecation সমস্যা সমাধান করবে

      - name: 💽 Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          channel: 'stable' # স্ট্যাবল চ্যানেল ব্যবহার করা সবচেয়ে নিরাপদ

      - name: 📦 Install Dependencies
        run: flutter pub get

      - name: 🔨 Build Web
        run: flutter build web --release

      - name: 🚀 Deploy via FTP
        uses: SamKirkland/FTP-Deploy-Action@v4.3.5
        with:
          server: ${{ secrets.FTP_SERVER }}
          username: ${{ secrets.FTP_USERNAME }}
          password: ${{ secrets.FTP_PASSWORD }}
          port: 21
          local-dir: build/web/
          server-dir: /
          # এটি false রাখা হয়েছে যাতে পারমিশন এরর না আসে। 
          # সব ঠিক থাকলে পরে true করতে পারেন।
          dangerous-clean-slate: false 
